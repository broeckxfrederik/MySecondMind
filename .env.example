# Copy this to .env and fill in your values
# cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Your public domain for this service (used in Traefik label)
DOMAIN=mind.yourdomain.com

# Traefik middleware name for Authentik forward auth.
# Examples:
#   authentik@file              (if defined in traefik/config/middlewares.yml)
#   authentik-proxy@docker      (if defined as Docker label on authentik outpost)
AUTHENTIK_MIDDLEWARE=authentik@file

# ── Optional ──────────────────────────────────────────────────────────────────

# Claude model to use for summaries and learning
# Default: claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# Microsoft Edge TTS voice
# Browse voices: https://speech.microsoft.com/portal/voicegallery
# Default: en-GB-RyanNeural (natural British male)
TTS_VOICE=en-GB-RyanNeural

# Number of user edits before preferences are automatically consolidated
# Default: 10
EDITS_BEFORE_CONSOLIDATION=10
