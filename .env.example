# Copy this to .env and fill in your values
# cp .env.example .env

# ── Deployment ────────────────────────────────────────────────────────────────
DOMAIN=mind.yourdomain.com
AUTHENTIK_MIDDLEWARE=authentik@file

# ── LLM Providers (add at least one) ─────────────────────────────────────────

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Groq — https://console.groq.com (free tier, very fast)
GROQ_API_KEY=gsk_...

# Google Gemini — https://aistudio.google.com/app/apikey (free: 1500 req/day)
GEMINI_API_KEY=AIza...

# Provider priority order — first = preferred, fallback left-to-right on rate limit
# Only providers with a configured API key above are actually used
PROVIDERS=anthropic,groq,gemini

# Seconds a provider stays cooling down after hitting a rate limit (default 60)
PROVIDER_COOLDOWN_SECONDS=60

# ── LLM Models (optional overrides) ──────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-1.5-flash

# ── TTS ───────────────────────────────────────────────────────────────────────
# Browse voices: https://speech.microsoft.com/portal/voicegallery
TTS_VOICE=en-GB-RyanNeural

# ── Learning loop ─────────────────────────────────────────────────────────────
EDITS_BEFORE_CONSOLIDATION=10

# ── Idle cross-validation ─────────────────────────────────────────────────────
# Minutes of inactivity before providers cross-check each other's summaries
IDLE_AFTER_MINUTES=60
# How often the validator loop checks (minutes)
VALIDATE_INTERVAL_MINUTES=30
